class Env {
  // YouTube Data API v3 key
  // Dapatkan dari: https://console.cloud.google.com/apis/credentials
  static const String youtubeApiKey = 'YOUR_YOUTUBE_API_KEY_HERE';
  
  // Firebase API Keys (Android)
  static const String firebaseApiKeyAndroid = 'YOUR_FIREBASE_ANDROID_KEY';
  
  // Firebase API Keys (iOS)
  static const String firebaseApiKeyIos = 'YOUR_FIREBASE_IOS_KEY';
}
